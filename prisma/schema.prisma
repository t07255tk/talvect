generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Submission {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  assessmentId String       @map("assessment_id") @db.Uuid
  userAnswers  UserAnswer[]
  startedAt    DateTime?    @map("started_at") @db.Timestamptz(6)
  completedAt  DateTime?    @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)

  assessment Assessment           @relation(fields: [assessmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user       User                 @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tagScores  SubmissionTagScore[]

  @@map("submissions")
}

model UserAnswer {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId String @map("submission_id") @db.Uuid

  question          AssessmentQuestion @relation(fields: [questionId], references: [id])
  questionId        String             @map("question_id") @db.Uuid
  userAnswerChoices UserAnswerChoice[]
  confidence        Float?
  comment           String?
  submission        Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([questionId])
  @@map("user_answers")
}

model UserAnswerChoice {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAnswerId String @map("user_answer_id") @db.Uuid
  choiceId     String @map("choice_id") @db.Uuid

  userAnswer UserAnswer       @relation(fields: [userAnswerId], references: [id], onDelete: Cascade)
  choice     AssessmentChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  orderIndex Int              @map("order_index")

  @@unique([userAnswerId, choiceId])
  @@map("user_answer_choices")
}

enum QuestionType {
  MULTIPLE_CHOICE_ORDERED
  ESSAY
}

model Assessment {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String               @db.VarChar
  description      String?              @db.VarChar
  questions        AssessmentQuestion[]
  timeLimitMinutes Int?                 @map("time_limit_minutes") @db.SmallInt
  createdBy        String               @map("created_by") @db.Uuid
  companyId        String               @map("company_id") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)

  submissions Submission[]
  user        User         @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company     Company      @relation(fields: [companyId], references: [id])

  tags AssessmentTag[]

  @@map("assessments")
}

model AssessmentQuestion {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String     @map("assessment_id") @db.Uuid

  type     QuestionType
  question String             @db.Text
  choices  AssessmentChoice[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  userAnswers UserAnswer[]

  @@map("assessment_questions")
}

model AssessmentChoice {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String             @map("question_id") @db.Uuid

  choiceId          String                      @map("choice_id") @db.Char(1)
  label             String                      @db.Text
  tagWeights        AssessmentChoiceTagWeight[]
  userAnswerChoices UserAnswerChoice[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("assessment_choices")
}

model AssessmentChoiceTagWeight {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  choiceId String @map("choice_id") @db.Uuid
  tagId    String @map("tag_id") @db.Uuid
  weight   Float

  choice AssessmentChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  tag    Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("assessment_choice_tag_weights")
}

model Company {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  users       UserCompany[]
  assessments Assessment[]

  @@map("companies")
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  hashedPassword String?   @map("hashed_password")
  provider       String    @default("credentials")
  providerId     String?   @map("provider_id")
  name           String?
  image          String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  submissions Submission[]
  assessments Assessment[]
  tags        Tag[]
  companies   UserCompany[]

  @@map("users")
}

enum Role {
  admin
  member
  applicant
}

model UserCompany {
  userId    String @map("user_id") @db.Uuid
  companyId String @map("company_id") @db.Uuid
  role      Role   @default(member)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("user_companies")
}

model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  isPreset    Boolean  @default(false) @map("is_preset")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                      User?                       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  assessments               AssessmentTag[]
  tag_scores                SubmissionTagScore[]
  AssessmentChoiceTagWeight AssessmentChoiceTagWeight[]

  @@unique([name, createdBy])
  @@map("tags")
}

model AssessmentTag {
  assessmentId String @map("assessment_id") @db.Uuid
  tagId        String @map("tag_id") @db.Uuid

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assessmentId, tagId])
  @@map("assessment_tags")
}

model SubmissionTagScore {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId String   @map("submission_id") @db.Uuid
  tagId        String   @map("tag_id") @db.Uuid
  total        Int // 関与した設問数
  correct      Int // 正解数
  rate         Float // 正答率 (0.0〜1.0)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([submissionId, tagId])
  @@map("submission_tag_scores")
}
